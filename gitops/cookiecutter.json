{
  "platform_name": "MyPlatform",
  "argo_namespace": "argocd",
  "project_name": "GitOps Configs: AppSets",
  "project_slug": "{{ cookiecutter.project_name.lower().replace(':', '').replace(' ', '_') }}",
  "repo_appsets": "kriipke/argocd-appsets-multirepo",
  "repo_charts": "kriipke/argocd-charts-multirepo",
  "init_git": true,
  "repo_appsets_branch": "main",
  "cluster_dev": "cluster-dev",
  "cluster_stage": "cluster-stage",
  "cluster_prod": "cluster-prod",
  "github_username": "your-org-or-username",
  "_copy_without_render": [
    ".github/workflows/*",
    ".github/actions/*",
    ".github/scripts/*"
  ],
  "__prompts__": {
    "cluster_dev": "Name of the dev cluster (as registered in Argo CD)",
    "cluster_stage": "Name of the stage cluster (as registered in Argo CD)",
    "cluster_prod": "Name of the prod cluster (as registered in Argo CD)"
  }
}
